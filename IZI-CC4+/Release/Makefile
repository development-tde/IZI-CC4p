	-$(RM) $(C_DEPS_AS_ARGS)   
	rm -rf "IZI-CC4+.elf" "IZI-CC4+.a" "IZI-CC4+.hex" "IZI-CC4+.bin" "IZI-CC4+.lss" "IZI-CC4+.eep" "IZI-CC4+.map" "IZI-CC4+.srec"
	